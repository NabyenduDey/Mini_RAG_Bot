TELEGRAM_BOT_TOKEN=your_token_from_botfather

OLLAMA_BASE_URL=http://127.0.0.1:11435
OLLAMA_CHAT_MODEL=llama3.2
# Faster, shorter answers (optional): cap tokens / context. Example: OLLAMA_NUM_PREDICT=256
# OLLAMA_NUM_PREDICT=256
# OLLAMA_NUM_CTX=2048
# OLLAMA_HTTP_TIMEOUT=120
# Lower = fewer invented “bonus” lines (default 0.2). Set 0 for maximum greediness.
# OLLAMA_TEMPERATURE=0.2

# Load embedding model at startup so the first /ask is not slow (default true).
# RAG_WARMUP_ON_START=true
# Larger batches speed up ingest; retrieval uses 1 string regardless.
# EMBEDDING_BATCH_SIZE=64
# Force device: cuda | cpu | mps (empty = SentenceTransformers default)
# EMBEDDING_DEVICE=

# Bot rule: every photo/screenshot must include a one-line caption in Telegram (enforced before processing).
#
# Image → text (assignment-friendly): blip2 | llava | clip_interrogator
# blip2 = BLIP-2 (good for screenshot / UI text). llava = heavier, very capable.
# clip_interrogator = artistic tags, not verbatim OCR.
# Also supported: blip_vqa | blip_caption | tesseract
IMAGE_TEXT_BACKEND=blip2
# Optional: override HF model id (defaults per backend)
# IMAGE_TEXT_MODEL=Salesforce/blip2-opt-2.7b
# IMAGE_TEXT_MODEL=llava-hf/llava-1.5-7b-hf
# Optional: full BLIP-2 OCR instruction (otherwise built-in prompt is used)
# BLIP2_OCR_PROMPT=Question: ... Answer:

# auto | cpu | cuda | cuda:0 | mps
HF_IMAGE_DEVICE=auto
HF_IMAGE_MAX_NEW_TOKENS=256
# BLIP-2 only: more beams = better transcript quality, slower (default 5). Upscale if max(w,h) < this edge.
# BLIP2_NUM_BEAMS=5
# BLIP2_UPSCALE_MIN_EDGE=640

# KNOWLEDGE_DIR=./knowledge
# DATA_DIR=./data
# SQLITE_PATH=./data/rag.db

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Chunks passed to the LLM after filtering (default 3). Lower = less cross-topic noise.
TOP_K=3
# Neighbors considered before distance filter (>= TOP_K). Larger = better filtering, slightly slower search.
# TOP_K_CANDIDATES=12
# Drop chunks farther than best_match_distance + margin. Leave blank to use default (0.20). Set 0 to disable (not recommended).
# RETRIEVAL_DISTANCE_MARGIN=0.20
# Stop at a big jump in distance between neighbors (default 0.13).
# RETRIEVAL_ELBOW_GAP=0.13

CHUNK_MAX_CHARS=480
CHUNK_OVERLAP=90
AUTO_REINGEST=true

# Windows + tesseract backend only:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
