TELEGRAM_BOT_TOKEN=your_token_from_botfather

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.2

# Image → text: blip_vqa (default) | blip_caption | llava | clip_interrogator | tesseract
IMAGE_TEXT_BACKEND=blip_vqa
# Optional: override HF model id (defaults are set per backend)
# IMAGE_TEXT_MODEL=Salesforce/blip-vqa-base
# IMAGE_TEXT_MODEL=llava-hf/llava-1.5-7b-hf

# auto | cpu | cuda | cuda:0 | mps
HF_IMAGE_DEVICE=auto
HF_IMAGE_MAX_NEW_TOKENS=256

# KNOWLEDGE_DIR=./knowledge
# DATA_DIR=./data
# SQLITE_PATH=./data/rag.db

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

TOP_K=5
CHUNK_MAX_CHARS=480
CHUNK_OVERLAP=90
AUTO_REINGEST=true

# Windows + tesseract backend only:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
